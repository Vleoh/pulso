NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulso_pais?schema=public
CORS_ORIGINS=*,http://localhost:3000,http://127.0.0.1:3000,https://*.vercel.app
ADMIN_EMAIL=admin@pulsopais.local
ADMIN_PASSWORD=cambiar-este-password
ADMIN_JWT_SECRET=cambiar-este-jwt-secret
ADMIN_COOKIE_NAME=pulso_admin_session
FRONTEND_PUBLIC_URL=http://localhost:3000
AI_FILTER_ENABLED=true
AI_FILTER_ENFORCE=true
AI_PROVIDER_ORDER=gemini,ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_OLLAMA_URL=http://localhost:11434
AI_MODEL=qwen3
AI_TIMEOUT_MS=20000
EDITORIAL_GUIDELINES_PATH=./editorial/pulso-pais-linea-editorial.txt
POLL_VOTE_SECRET=cambiar-este-secret-encuestas
USER_SESSION_COOKIE_NAME=pulso_user_session
USER_SESSION_SECRET=cambiar-este-session-secret-usuarios
USER_SESSION_HOURS=720
