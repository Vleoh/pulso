generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["pulso"]
}

enum NewsStatus {
  DRAFT
  PUBLISHED

  @@schema("pulso")
}

enum PollStatus {
  DRAFT
  PUBLISHED

  @@schema("pulso")
}

enum NewsSection {
  NACION
  PROVINCIAS
  MUNICIPIOS
  OPINION
  ENTREVISTAS
  PUBLINOTAS
  RADAR_ELECTORAL
  ECONOMIA
  INTERNACIONALES
  DISTRITOS

  @@schema("pulso")
}

enum AiDecision {
  ALLOW
  REVIEW
  REJECT

  @@schema("pulso")
}

enum Province {
  CABA
  BUENOS_AIRES
  CATAMARCA
  CHACO
  CHUBUT
  CORDOBA
  CORRIENTES
  ENTRE_RIOS
  FORMOSA
  JUJUY
  LA_PAMPA
  LA_RIOJA
  MENDOZA
  MISIONES
  NEUQUEN
  RIO_NEGRO
  SALTA
  SAN_JUAN
  SAN_LUIS
  SANTA_CRUZ
  SANTA_FE
  SANTIAGO_DEL_ESTERO
  TIERRA_DEL_FUEGO
  TUCUMAN

  @@schema("pulso")
}

model News {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  kicker      String?
  excerpt     String?
  body        String?
  imageUrl    String?
  sourceName  String?
  sourceUrl   String?
  authorName  String?
  section     NewsSection
  province    Province?
  tags        String[]
  isSponsored Boolean    @default(false)
  isFeatured  Boolean    @default(false)
  isHero      Boolean    @default(false)
  isInterview Boolean    @default(false)
  isOpinion   Boolean    @default(false)
  isRadar     Boolean    @default(false)
  status      NewsStatus @default(DRAFT)
  aiDecision  AiDecision @default(REVIEW)
  aiReason    String?
  aiScore     Int?
  aiWarnings  String[]
  aiModel     String?
  aiEvaluatedAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([section, publishedAt])
  @@index([province, publishedAt])
  @@index([aiDecision, publishedAt])
  @@schema("pulso")
}

model SiteSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("pulso")
}

model Poll {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  question     String
  hookLabel    String      @default("Encuesta Nacional")
  footerCta    String      @default("Vota y explica por que")
  description  String?
  interviewUrl String?
  coverImageUrl String?
  status       PollStatus  @default(DRAFT)
  isFeatured   Boolean     @default(false)
  startsAt     DateTime?
  endsAt       DateTime?
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  options      PollOption[]
  votes        PollVote[]

  @@index([status, publishedAt])
  @@index([isFeatured, publishedAt])
  @@schema("pulso")
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int
  colorHex  String?
  emoji     String?
  createdAt DateTime @default(now())
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
  @@schema("pulso")
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  voterHash String
  sourceRef String?
  reasonText String?
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterHash])
  @@index([pollId, createdAt])
  @@index([optionId])
  @@schema("pulso")
}
